# Server
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Supabase (اختياري — لو أردت مزامنة النتائج مباشرةً)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Models
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
OCR_LANGS=arabic,en

# Matching thresholds
MIN_SIMILARITY=0.55
MERGE_CREDIT_TOLERANCE=1.5
